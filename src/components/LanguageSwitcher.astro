---
interface Props {
  currentLang: 'en' | 'vi';
  currentPage: string;
}

const { currentLang, currentPage } = Astro.props;

const switchTo = currentLang === 'en' ? 'vi' : 'en';
const path = currentPage === '' ? '/' : `/${currentPage}`;
const switchPath = currentLang === 'en' ? `/vi${path}` : path;
---

<a
  href={switchPath}
  class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-accent-900/50 border border-accent-700/30 text-accent-300/70 hover:text-accent-300 hover:border-accent-500/50 transition-all duration-300 text-sm font-medium"
>
  <i class="fas fa-globe text-xs"></i>
  <span>{switchTo === 'vi' ? 'VI' : 'EN'}</span>
</a>
