---
const { correctPassword = '02032002' } = Astro.props;
---

<div id="blog-auth-overlay" class="fixed inset-0 z-40 flex items-center justify-center bg-black/80 backdrop-blur-sm">
  <div class="bg-dark-card border border-dark-border rounded-2xl p-8 w-full max-w-md mx-4 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-500/60 via-accent-700/40 to-transparent"></div>
    
    <div class="text-center mb-6">
      <div class="w-12 h-12 rounded-full bg-accent-900/60 border border-accent-700/30 flex items-center justify-center mx-auto mb-4">
        <i class="fas fa-lock text-accent-400 text-xl"></i>
      </div>
      <h2 class="text-xl font-bold text-accent-200">Truy cập Blog</h2>
      <p class="text-accent-400/60 text-sm mt-2">Nhập mật khẩu để tiếp tục</p>
    </div>

    <form id="blog-auth-form" class="space-y-4">
      <div>
        <input 
          type="password" 
          id="blog-password" 
          class="w-full px-4 py-3 bg-dark-bg border border-dark-border rounded-lg text-accent-200 placeholder-accent-500/40 focus:outline-none focus:border-accent-500/50 transition-colors"
          placeholder="Mật khẩu..."
          autocomplete="current-password"
        />
        <p id="blog-auth-error" class="text-red-400 text-sm mt-2 hidden">Không có quyền truy cập</p>
      </div>
      
      <button 
        type="submit"
        class="w-full py-3 px-4 bg-accent-600 hover:bg-accent-500 text-white font-medium rounded-lg transition-colors"
      >
        Xác nhận
      </button>
    </form>
  </div>
</div>

<script define:vars={{ correctPassword }}>
  const AUTH_KEY = 'blog_authenticated';
  const EXPIRATION_TIME = 7 * 24 * 60 * 60 * 1000; // 1 week in milliseconds
  const overlay = document.getElementById('blog-auth-overlay');
  const form = document.getElementById('blog-auth-form');
  const input = document.getElementById('blog-password');
  const errorMsg = document.getElementById('blog-auth-error');
  
  function checkAuth() {
    const savedTime = localStorage.getItem(AUTH_KEY);
    if (!savedTime) return false;
    
    const timeDiff = Date.now() - parseInt(savedTime, 10);
    if (isNaN(timeDiff) || timeDiff > EXPIRATION_TIME) {
      localStorage.removeItem(AUTH_KEY);
      return false;
    }
    return true;
  }
  
  function showOverlay() {
    overlay.style.display = 'flex';
    input.focus();
  }
  
  function hideOverlay() {
    overlay.style.display = 'none';
    localStorage.setItem(AUTH_KEY, Date.now().toString());
  }
  
  function showError() {
    errorMsg.classList.remove('hidden');
    input.classList.add('border-red-500');
    input.value = '';
    input.focus();
  }
  
  // Check on load
  if (!checkAuth()) {
    showOverlay();
  } else {
    overlay.style.display = 'none';
  }
  
  // Handle form submit
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const password = input.value;
    
    if (password === correctPassword) {
      hideOverlay();
    } else {
      showError();
    }
  });
  
  // Handle Enter key
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      form.dispatchEvent(new Event('submit'));
    }
  });
</script>
