---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import en from '../i18n/en.json';

const t = en;
---

<BaseLayout title={t.site.title}>
  <Header currentPage="" lang="en" t={t} />
  <main class="pt-20">
    <section class="min-h-screen flex items-center justify-center relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-accent-700/15 via-accent-900/5 to-transparent"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-accent-500/10 via-accent-900/5 to-transparent"></div>

      <div class="max-w-4xl mx-auto px-6 py-20 relative z-10 text-center">
        <div class="flex-shrink-0 mx-auto mb-8">
          <div class="relative inline-block">
            <div class="absolute -inset-1 bg-gradient-to-br from-accent-500 via-accent-700 to-accent-900 rounded-full opacity-50 blur-lg"></div>
            <div class="relative w-32 h-32 md:w-40 md:h-40 rounded-full bg-gradient-to-br from-accent-300 via-accent-500 to-accent-700 p-0.5">
              <div class="w-full h-full rounded-full bg-dark-card flex items-center justify-center overflow-hidden">
                <img src="/img/avatar.jpg" alt="Huy Hieu Nguyen" class="w-full h-full object-cover" />
              </div>
            </div>
          </div>
        </div>

        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-900/50 border border-accent-700/30 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-red animate-pulse"></span>
          <span class="text-accent-300 text-sm font-medium">{t.home.badge}</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6">
          {t.home.greeting} <span class="bg-gradient-to-r from-accent-200 via-accent-400 to-accent-600 bg-clip-text text-transparent">Huy Hieu Nguyen</span>
        </h1>

        <p class="text-accent-300/60 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-4">
          {t.home.bio}
        </p>

        <p class="text-accent-300/40 text-base max-w-xl mx-auto mb-12">
          {t.home.bioSecondary}
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto">
          <a href="/about" class="group p-6 rounded-2xl bg-dark-card border border-dark-border hover:border-accent-700/50 transition-all duration-300 hover:-translate-y-1 text-left">
            <i class="fas fa-user text-accent-400 mb-3 text-xl"></i>
            <h3 class="text-lg font-semibold text-accent-200 mb-1">{t.common.aboutMe}</h3>
            <p class="text-accent-300/50 text-sm">{t.common.backgroundSkills}</p>
          </a>
          <a href="/research" class="group p-6 rounded-2xl bg-dark-card border border-dark-border hover:border-accent-700/50 transition-all duration-300 hover:-translate-y-1 text-left">
            <i class="fas fa-microscope text-accent-400 mb-3 text-xl"></i>
            <h3 class="text-lg font-semibold text-accent-200 mb-1">{t.nav.research}</h3>
            <p class="text-accent-300/50 text-sm">{t.common.academicPubs}</p>
          </a>
          <a href="/projects" class="group p-6 rounded-2xl bg-dark-card border border-dark-border hover:border-accent-700/50 transition-all duration-300 hover:-translate-y-1 text-left">
            <i class="fas fa-code text-accent-400 mb-3 text-xl"></i>
            <h3 class="text-lg font-semibold text-accent-200 mb-1">{t.nav.projects}</h3>
            <p class="text-accent-300/50 text-sm">{t.common.personalWork}</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
