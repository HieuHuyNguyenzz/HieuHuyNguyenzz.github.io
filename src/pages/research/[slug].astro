---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import researches from '../../data/research.json';
import en from '../../i18n/en.json';

export function getStaticPaths() {
  return researches.map(r => ({
    params: { slug: r.slug },
    props: { research: r },
  }));
}

const { research } = Astro.props;
const t = en;

const statusLabels: Record<string, string> = {
  published: t.common.published,
  'in-progress': t.common.inProgress,
  planned: t.common.planned,
};
const statusColors: Record<string, string> = {
  published: 'bg-accent-400/20 text-accent-400 border-accent-400/30',
  'in-progress': 'bg-accent-500/20 text-accent-500 border-accent-500/30',
  planned: 'bg-accent-700/20 text-accent-700 border-accent-700/30',
};
---

<BaseLayout title={`${research.title} | Huy Hieu Nguyen`} lang="en">
  <Header currentPage="research" lang="en" t={t} />
  <main class="pt-20">
    <section class="py-24 relative">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-accent-700/8 via-accent-900/3 to-transparent"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <a href="/research" class="inline-flex items-center gap-2 text-accent-400 hover:text-accent-300 transition-colors mb-8 text-sm">
          <i class="fas fa-arrow-left text-xs"></i> {t.common.backToResearch}
        </a>

        <div class="bg-dark-card border border-dark-border rounded-2xl p-8 md:p-12 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-500/60 via-accent-700/40 to-transparent"></div>

          <div class="flex items-center gap-3 mb-4">
            <span class={`px-3 py-1 text-xs rounded-full border ${statusColors[research.status] || statusColors.planned}`}>
              {statusLabels[research.status] || statusLabels.planned}
            </span>
            <span class="text-accent-300/40 text-sm">{research.year}</span>
          </div>

          <h1 class="text-2xl md:text-3xl font-bold text-accent-200 mb-6">
            {research.title}
          </h1>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8 pb-8 border-b border-dark-border">
            <div>
              <p class="text-xs text-accent-300/40 mb-1 uppercase tracking-wide">{t.research.sections.authors}</p>
              <p class="text-accent-300/70 text-sm">{research.authors}</p>
            </div>
            <div>
              <p class="text-xs text-accent-300/40 mb-1 uppercase tracking-wide">{t.research.sections.venue}</p>
              <p class="text-accent-300/70 text-sm">{research.venue}</p>
            </div>
          </div>

          {research.image && (
            <div class="mb-8 rounded-xl overflow-hidden border border-dark-border">
              <img src={research.image} alt={research.title} class="w-full h-auto object-cover" />
            </div>
          )}

          <div class="mb-8">
            <h2 class="text-lg font-semibold text-accent-200 mb-4 flex items-center gap-2">
              <i class="fas fa-file-alt text-accent-400 text-sm"></i> {t.research.sections.abstract}
            </h2>
            <p class="text-accent-300/60 leading-relaxed">
              {research.abstract}
            </p>
          </div>

          <div class="mb-8">
            <h2 class="text-lg font-semibold text-accent-200 mb-4 flex items-center gap-2">
              <i class="fas fa-tags text-accent-400 text-sm"></i> {t.research.sections.keywords}
            </h2>
            <div class="flex flex-wrap gap-2">
              {research.keywords.map(tag => (
                <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          {research.context && (
            <div class="mb-8">
              <h2 class="text-lg font-semibold text-accent-200 mb-4 flex items-center gap-2">
                <i class="fas fa-info-circle text-accent-400 text-sm"></i> Context
              </h2>
              <p class="text-accent-300/60 leading-relaxed">
                {research.context}
              </p>
            </div>
          )}

          {research.myComments && (
            <div class="mb-8 p-6 bg-accent-900/20 rounded-xl border border-accent-700/30">
              <h2 class="text-lg font-semibold text-accent-200 mb-3 flex items-center gap-2">
                <i class="fas fa-comment-dots text-accent-400 text-sm"></i> My Thoughts
              </h2>
              <p class="text-accent-300/70 leading-relaxed italic">
                {research.myComments}
              </p>
            </div>
          )}

          <div class="flex flex-wrap gap-4 pt-6 border-t border-dark-border">
            {research.pdfLink && research.pdfLink !== '#' && (
              <a href={research.pdfLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-accent-900/60 border border-accent-700/30 text-accent-400 hover:border-accent-500/50 hover:text-accent-300 transition-all duration-300 text-sm">
                <i class="fas fa-file-pdf"></i> {t.common.viewPdf}
              </a>
            )}
            {research.codeLink && research.codeLink !== '#' && (
              <a href={research.codeLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-accent-900/60 border border-accent-700/30 text-accent-400 hover:border-accent-500/50 hover:text-accent-300 transition-all duration-300 text-sm">
                <i class="fab fa-github"></i> {t.common.viewCode}
              </a>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
