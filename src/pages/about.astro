---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import en from '../i18n/en.json';

const t = en as any;

const sections = [
  { id: 'introduction', title: t.about.introduction.title, icon: 'fa-user' },
  { id: 'beyond-work', title: t.about.beyondWork.title, icon: 'fa-coffee' },
  { id: 'education', title: t.about.education.title, icon: 'fa-graduation-cap' },
  { id: 'experience', title: t.about.experience.title, icon: 'fa-briefcase' },
  { id: 'skills', title: t.about.skills.title, icon: 'fa-cogs' },
];
---

<BaseLayout title={`${t.about.pageTitle} | Huy Hieu Nguyen`} lang="en">
  <Header currentPage="about" lang="en" t={t} />
  <main class="pt-20">
    <section class="py-24 relative">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-accent-700/8 via-accent-900/3 to-transparent"></div>

      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-900/50 border border-accent-700/30 mb-4">
            <span class="text-accent-400 text-sm font-medium">{t.about.pageSubtitle}</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold">
            {t.about.pageTitle} <span class="bg-gradient-to-r from-accent-200 via-accent-400 to-accent-600 bg-clip-text text-transparent">Me</span>
          </h1>
        </div>

        <div class="lg:flex lg:gap-8">
          <nav class="hidden lg:block w-48 flex-shrink-0">
            <div class="sticky top-24 space-y-1" id="toc">
              <span class="text-xs uppercase tracking-wider text-accent-400/50 block px-4 mb-2">Contents</span>
              {sections.map(section => (
                <a
                  href={`#${section.id}`}
                  class="toc-link block py-2 px-4 text-sm text-accent-300/60 hover:text-accent-300 hover:bg-accent-900/30 rounded-lg transition-all duration-300"
                  data-section={section.id}
                >
                  {section.title}
                </a>
              ))}
            </div>
          </nav>

          <div class="flex-1 max-w-3xl mx-auto space-y-16">
            <div id="introduction" class="bg-dark-card border border-dark-border rounded-2xl p-8 relative overflow-hidden scroll-mt-24">
              <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-500/60 via-accent-700/40 to-transparent"></div>
              <h2 class="text-xl font-semibold text-accent-200 mb-4 flex items-center gap-3">
                <i class="fas fa-user text-accent-400"></i> {t.about.introduction.title}
              </h2>
              <p class="text-accent-300/60 leading-relaxed">
                {t.about.introduction.text}
              </p>
            </div>

            <div id="beyond-work" class="bg-dark-card border border-dark-border rounded-2xl p-8 relative overflow-hidden scroll-mt-24">
              <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-500/60 via-accent-700/40 to-transparent"></div>
              <h2 class="text-xl font-semibold text-accent-200 mb-4 flex items-center gap-3">
                <i class="fas fa-coffee text-accent-400"></i> {t.about.beyondWork.title}
              </h2>
              <p class="text-accent-300/60 leading-relaxed">
                {t.about.beyondWork.text}
              </p>
            </div>

            <div id="education" class="bg-dark-card border border-dark-border rounded-2xl p-8 relative overflow-hidden scroll-mt-24">
              <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-500/60 via-accent-700/40 to-transparent"></div>
              <h2 class="text-xl font-semibold text-accent-200 mb-6 flex items-center gap-3">
                <i class="fas fa-graduation-cap text-accent-400"></i> {t.about.education.title}
              </h2>
              <div class="space-y-6">
                {t.about.education.entries.map((entry, i) => (
                  <div class:list={["flex flex-col md:flex-row md:items-start gap-4", i < t.about.education.entries.length - 1 ? "pb-6 border-b border-dark-border" : ""]}>
                    <div class="flex-shrink-0 w-32">
                      <span class="text-accent-400 text-sm font-medium">{entry.period}</span>
                    </div>
                    <div>
                      <h3 class="text-accent-200 font-semibold mb-1">{entry.degree}</h3>
                      <p class="text-accent-300/50 text-sm">{entry.institution}</p>
                      <p class="text-accent-300/40 text-sm mt-1">{entry.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div id="experience" class="bg-dark-card border border-dark-border rounded-2xl p-8 relative overflow-hidden scroll-mt-24">
              <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-500/60 via-accent-700/40 to-transparent"></div>
              <h2 class="text-xl font-semibold text-accent-200 mb-6 flex items-center gap-3">
                <i class="fas fa-briefcase text-accent-400"></i> {t.about.experience.title}
              </h2>
              <div class="space-y-6">
                {t.about.experience.entries.map((entry, i) => (
                  <div class:list={["flex flex-col md:flex-row md:items-start gap-4", i < t.about.experience.entries.length - 1 ? "pb-6 border-b border-dark-border" : ""]}>
                    <div class="flex-shrink-0 w-32">
                      <span class="text-accent-400 text-sm font-medium">{entry.period}</span>
                    </div>
                    <div>
                      <h3 class="text-accent-200 font-semibold mb-1">{entry.role}</h3>
                      <p class="text-accent-300/50 text-sm">{entry.company}</p>
                      {Array.isArray(entry.desc) ? (
                        <ul class="mt-2 space-y-1">
                          {entry.desc.map((item) => (
                            <li class="text-accent-300/40 text-sm list-disc list-inside">{item}</li>
                          ))}
                        </ul>
                      ) : (
                        <p class="text-accent-300/40 text-sm mt-1">{entry.desc}</p>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div id="skills" class="bg-dark-card border border-dark-border rounded-2xl p-8 relative overflow-hidden scroll-mt-24">
              <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-500/60 via-accent-700/40 to-transparent"></div>
              <h2 class="text-xl font-semibold text-accent-200 mb-6 flex items-center gap-3">
                <i class="fas fa-cogs text-accent-400"></i> {t.about.skills.title}
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <h3 class="text-accent-300 font-medium mb-3 text-sm uppercase tracking-wide">{t.about.skills.programming}</h3>
                  <div class="flex flex-wrap gap-2">
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">Python</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">C++</span>
                  </div>
                </div>
                <div>
                  <h3 class="text-accent-300 font-medium mb-3 text-sm uppercase tracking-wide">{t.about.skills.frameworks}</h3>
                  <div class="flex flex-wrap gap-2">
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">NumPy</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">Pandas</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">TensorFlow</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">PyTorch</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">Scikit-learn</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">Matplotlib</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">C++ STL</span>
                  </div>
                </div>
                <div>
                  <h3 class="text-accent-300 font-medium mb-3 text-sm uppercase tracking-wide">{t.about.skills.tools}</h3>
                  <div class="flex flex-wrap gap-2">
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">Data Structures and Algorithms</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">Machine Learning</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">Deep Learning</span>
                    <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">Data Science</span>
                  </div>
                </div>
                <div>
                  <h3 class="text-accent-300 font-medium mb-3 text-sm uppercase tracking-wide">{t.about.skills.languages}</h3>
                  <div class="flex flex-wrap gap-2">
                    {t.about.skills.certificatesList.map((cert) => (
                      <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">{cert}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const tocLinks = document.querySelectorAll('.toc-link');
  const sections = document.querySelectorAll('div[id]');

  const observerOptions = {
    root: null,
    rootMargin: '-10% 0px -10% 0px',
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        tocLinks.forEach(link => {
          link.classList.remove('text-accent-300', 'bg-accent-900/50');
          link.classList.add('text-accent-300/60');
          if (link.getAttribute('data-section') === id) {
            link.classList.add('text-accent-300', 'bg-accent-900/50');
            link.classList.remove('text-accent-300/60');
          }
        });
      }
    });
  }, observerOptions);

  sections.forEach(section => observer.observe(section));

  tocLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = link.getAttribute('href').substring(1);
      const targetSection = document.getElementById(targetId);
      if (targetSection) {
        targetSection.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>