---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import awardsVi from '../../../../data/awards-vi.json';
import activitiesVi from '../../../../data/activities-vi.json';
import vi from '../../../../i18n/vi.json';

const t = vi;

export function getStaticPaths() {
  return [
    ...awardsVi.map(a => ({ params: { type: 'award', slug: a.slug }, props: { item: a } })),
    ...activitiesVi.map(a => ({ params: { type: 'activity', slug: a.slug }, props: { item: a } })),
  ];
}

const { item } = Astro.props;
---

<BaseLayout title={`${item.title} | Nguyễn Huy Hiệu`} lang="vi">
  <Header currentPage="activities" lang="vi" t={t} />
  <main class="pt-20">
    <section class="py-24 relative">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-accent-700/8 via-accent-900/3 to-transparent"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <a href="/vi/activities" class="inline-flex items-center gap-2 text-accent-400 hover:text-accent-300 transition-colors mb-8 text-sm">
          <i class="fas fa-arrow-left text-xs"></i> Quay lại Hoạt động & Giải thưởng
        </a>

        <div class="bg-dark-card border border-dark-border rounded-2xl p-8 md:p-12 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-500/60 via-accent-700/40 to-transparent"></div>

          <div class="flex items-center gap-3 mb-4">
            <span class="px-2 py-0.5 text-xs rounded-full bg-accent-900/40 text-accent-300/50 border border-accent-700/20">{item.level || item.period}</span>
            <span class="text-accent-300/30 text-sm">{item.year || ''}</span>
          </div>

          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-lg bg-accent-900/60 border border-accent-700/30 flex items-center justify-center">
              <i class={`fas ${item.icon} text-accent-400 text-lg`}></i>
            </div>
            <div>
              <h1 class="text-2xl md:text-3xl font-bold text-accent-200">{item.title}</h1>
              <p class="text-accent-400 text-lg mt-1">{item.prize || item.role}</p>
            </div>
          </div>

          <div class="mb-8">
            <h2 class="text-lg font-semibold text-accent-200 mb-3 flex items-center gap-2">
              <i class="fas fa-info-circle text-accent-400 text-sm"></i> Tổng quan
            </h2>
            <p class="text-accent-300/60 leading-relaxed">{item.description}</p>
          </div>

          <div class="mb-8">
            <h2 class="text-lg font-semibold text-accent-200 mb-3 flex items-center gap-2">
              <i class="fas fa-file-alt text-accent-400 text-sm"></i> Chi tiết
            </h2>
            <p class="text-accent-300/60 leading-relaxed">{item.details}</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
