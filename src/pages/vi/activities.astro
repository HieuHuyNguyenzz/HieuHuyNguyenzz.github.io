---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import awards from '../../data/awards.json';
import activities from '../../data/activities.json';
import vi from '../../i18n/vi.json';

const t = vi;
---

<BaseLayout title={`${t.activities.pageTitle} | Nguyễn Huy Hiệu`} lang="vi">
  <Header currentPage="activities" lang="vi" t={t} />
  <main class="pt-20">
    <section class="py-24 relative">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-accent-700/8 via-accent-900/3 to-transparent"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-900/50 border border-accent-700/30 mb-4">
            <span class="text-accent-400 text-sm font-medium">{t.activities.pageSubtitle}</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold">
            {t.activities.pageTitle}
          </h1>
          <p class="text-accent-300/50 mt-4 max-w-lg mx-auto">
            {t.activities.pageDesc}
          </p>
        </div>

        <div class="mb-16">
          <h2 class="text-xl font-semibold text-accent-200 mb-8 flex items-center gap-3">
            <i class="fas fa-trophy text-accent-400"></i> {t.activities.sections.awards}
          </h2>

          <div class="relative">
            <div class="absolute left-4 top-0 bottom-0 w-px bg-gradient-to-b from-accent-500/40 via-accent-700/20 to-transparent"></div>

            <div class="space-y-6">
              {awards.map((a) => (
                <div class="relative flex gap-6 group">
                  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-dark-card border-2 border-accent-500/40 flex items-center justify-center z-10 group-hover:border-accent-400 group-hover:shadow-lg group-hover:shadow-accent-500/20 transition-all duration-300">
                    <i class={`fas ${a.icon} text-accent-400 text-xs`}></i>
                  </div>

                  <div class="flex-1 bg-dark-card border border-dark-border rounded-xl p-5 hover:border-accent-500/30 transition-all duration-300 group-hover:-translate-y-0.5">
                    <div class="flex items-start justify-between gap-3 mb-2">
                      <div>
                        <h3 class="text-accent-200 font-semibold">{a.title}</h3>
                        <p class="text-accent-400 text-sm mt-1">{a.prize}</p>
                      </div>
                      <div class="flex flex-col items-end gap-1">
                        <span class="text-accent-300/30 text-xs whitespace-nowrap">{a.year}</span>
                        <span class="px-2 py-0.5 text-xs rounded-full bg-accent-900/40 text-accent-300/50 border border-accent-700/20">{a.level}</span>
                      </div>
                    </div>
                    <p class="text-accent-300/50 text-sm leading-relaxed mt-2">
                      {a.description}
                    </p>
                    <a href={`/vi/activities/award/${a.slug}`} class="inline-flex items-center gap-2 text-sm text-accent-400 hover:text-accent-300 transition-colors mt-3">
                      {t.common.viewDetails} <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform duration-300"></i>
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-accent-200 mb-8 flex items-center gap-3">
            <i class="fas fa-users text-accent-400"></i> {t.activities.sections.activities}
          </h2>

          <div class="relative">
            <div class="absolute left-4 top-0 bottom-0 w-px bg-gradient-to-b from-accent-400/40 via-accent-700/20 to-transparent"></div>

            <div class="space-y-6">
              {activities.map((a) => (
                <div class="relative flex gap-6 group">
                  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-dark-card border-2 border-accent-400/40 flex items-center justify-center z-10 group-hover:border-accent-300 group-hover:shadow-lg group-hover:shadow-accent-400/20 transition-all duration-300">
                    <i class={`fas ${a.icon} text-accent-400 text-xs`}></i>
                  </div>

                  <div class="flex-1 bg-dark-card border border-dark-border rounded-xl p-5 hover:border-accent-400/30 transition-all duration-300 group-hover:-translate-y-0.5">
                    <div class="flex items-start justify-between gap-3 mb-2">
                      <div>
                        <h3 class="text-accent-200 font-semibold">{a.title}</h3>
                        <p class="text-accent-400 text-sm">{a.role}</p>
                      </div>
                      <span class="text-accent-300/30 text-xs whitespace-nowrap">{a.period}</span>
                    </div>
                    <p class="text-accent-300/50 text-sm leading-relaxed mt-2">
                      {a.description}
                    </p>
                    <a href={`/vi/activities/activity/${a.slug}`} class="inline-flex items-center gap-2 text-sm text-accent-400 hover:text-accent-300 transition-colors mt-3">
                      {t.common.viewDetails} <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform duration-300"></i>
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
