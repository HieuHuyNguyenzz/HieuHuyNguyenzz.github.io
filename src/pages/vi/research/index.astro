---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import researches from '../../../data/research.json';
import vi from '../../../i18n/vi.json';

const t = vi;

const allKeywords = [...new Set(researches.flatMap(r => r.keywords || []))].sort();
const sortedResearches = [...researches].sort((a, b) => b.year - a.year);

const sectionOrder = ['published', 'under-review', 'in-progress'] as const;

function getCardClasses(isFirstAuthor: boolean): string {
  if (isFirstAuthor) {
    return 'border-accent-500/40 hover:border-accent-500/70 hover:shadow-accent-500/10';
  }
  return 'border-dark-border hover:border-accent-300/30 hover:shadow-accent-300/5';
}

function getTopLineClasses(isFirstAuthor: boolean): string {
  if (isFirstAuthor) {
    return 'bg-gradient-to-r from-accent-500/80 via-accent-700/50 to-transparent group-hover:from-accent-400/90 group-hover:via-accent-500/70';
  }
  return 'bg-gradient-to-r from-accent-300/40 via-accent-500/20 to-transparent group-hover:from-accent-300/60 group-hover:via-accent-500/40';
}

function getRoleBadge(isFirstAuthor: boolean): string {
  if (isFirstAuthor) {
    return 'px-2 py-0.5 text-xs rounded-full bg-accent-500/20 text-accent-500 border border-accent-500/40 font-medium';
  }
  return 'px-2 py-0.5 text-xs rounded-full bg-accent-300/10 text-accent-300/60 border border-accent-300/20';
}

function getTitleClasses(isFirstAuthor: boolean): string {
  if (isFirstAuthor) {
    return 'text-lg font-semibold text-accent-200 group-hover:text-accent-300 transition-colors duration-300';
  }
  return 'text-lg font-medium text-accent-300/80 group-hover:text-accent-300 transition-colors duration-300';
}

function getMetaClasses(isFirstAuthor: boolean): string {
  if (isFirstAuthor) {
    return 'text-accent-400';
  }
  return 'text-accent-300/50';
}

function getContributionClasses(isFirstAuthor: boolean): string {
  if (isFirstAuthor) {
    return 'text-accent-300/60';
  }
  return 'text-accent-300/40';
}
---

<BaseLayout title={`${t.research.pageTitle} | Nguyễn Huy Hiệu`} lang="vi">
  <Header currentPage="research" lang="vi" t={t} />
  <main class="pt-20">
    <section class="py-24 relative">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-accent-700/8 via-accent-900/3 to-transparent"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-900/50 border border-accent-700/30 mb-4">
            <span class="text-accent-400 text-sm font-medium">{t.research.pageSubtitle}</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold">
            {t.research.pageTitle} <span class="bg-gradient-to-r from-accent-200 via-accent-400 to-accent-600 bg-clip-text text-transparent">Khoa học</span>
          </h1>
          <p class="text-accent-300/50 mt-4 max-w-lg mx-auto">
            {t.research.pageDesc}
          </p>
        </div>

        <div class="mb-8">
          <div class="flex flex-wrap gap-2" id="keyword-filters">
            <button class="filter-btn active px-3 py-1.5 text-xs rounded-full bg-accent-500/20 text-accent-400 border border-accent-500/40 font-medium transition-all" data-filter="all">
              Tất cả
            </button>
            {allKeywords.map(keyword => (
              <button class="filter-btn px-3 py-1.5 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30 hover:border-accent-500/50 transition-all" data-filter={keyword}>
                {keyword}
              </button>
            ))}
          </div>
        </div>

        <div id="research-list" class="space-y-12">
          {sortedResearches.map(r => (
            <div class="research-card" data-keywords={JSON.stringify(r.keywords || [])} data-year={r.year}>
              <div class="mb-8">
                <h2 class="text-xl font-semibold text-accent-200 mb-6 flex items-center gap-3">
                  <span class="w-8 h-px bg-accent-500/50"></span>
                  {r.title}
                  <span class="text-sm font-normal text-accent-300/40">({r.year})</span>
                </h2>

                <div class="space-y-4">
                  <div class={`group relative bg-dark-card border rounded-2xl p-6 transition-all duration-500 overflow-hidden ${getCardClasses(r.isFirstAuthor)}`}>
                    <div class={`absolute top-0 left-0 w-full h-px transition-all duration-500 ${getTopLineClasses(r.isFirstAuthor)}`}></div>

                    <div class="flex items-start justify-between gap-4 mb-3">
                      <h3 class={getTitleClasses(r.isFirstAuthor)}>
                        {r.title}
                      </h3>
                      {r.isFirstAuthor && (
                        <span class={getRoleBadge(r.isFirstAuthor)}>
                          {t.common.firstAuthor}
                        </span>
                      )}
                    </div>

                    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-3 text-sm">
                      <span class={getMetaClasses(r.isFirstAuthor)}>
                        <i class="fas fa-user-tag text-xs mr-1"></i> {r.role}
                      </span>
                      <span class="text-accent-300/50">
                        <i class="fas fa-building text-xs mr-1"></i> {r.venue}
                      </span>
                      <span class="text-accent-300/40">
                        <i class="fas fa-calendar text-xs mr-1"></i> {r.year}
                      </span>
                    </div>

                    <div class="flex flex-wrap gap-2 mb-3">
                      {(r.keywords || []).map(keyword => (
                        <span class="px-2 py-0.5 text-xs rounded-full bg-accent-900/40 text-accent-400/70 border border-accent-700/20">
                          {keyword}
                        </span>
                      ))}
                    </div>

                    <p class={`text-sm leading-relaxed mb-4 ${getContributionClasses(r.isFirstAuthor)}`}>
                      {r.contribution}
                    </p>

                    <div class="flex flex-wrap items-center gap-3">
                      <a href={`/vi/research/${r.slug}`} class="inline-flex items-center gap-2 text-sm text-accent-400 hover:text-accent-300 transition-colors">
                        {t.common.viewDetails} <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform duration-300"></i>
                      </a>
                      {r.pdfLink && r.pdfLink !== '#' && (
                        <a href={r.pdfLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs text-accent-300/50 hover:text-accent-400 transition-colors">
                          <i class="fas fa-file-pdf"></i> PDF
                        </a>
                      )}
                      {r.codeLink && r.codeLink !== '#' && (
                        <a href={r.codeLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs text-accent-300/50 hover:text-accent-400 transition-colors">
                          <i class="fab fa-github"></i> Code
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div id="no-results" class="hidden text-center py-12">
          <p class="text-accent-300/50">Không tìm thấy bài nghiên cứu nào.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const researchCards = document.querySelectorAll('.research-card');
  const noResults = document.getElementById('no-results');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      
      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-accent-500/20', 'text-accent-400', 'border-accent-500/40');
        b.classList.add('bg-accent-900/60', 'text-accent-400', 'border-accent-700/30');
      });
      btn.classList.add('active', 'bg-accent-500/20', 'text-accent-400', 'border-accent-500/40');
      btn.classList.remove('bg-accent-900/60', 'border-accent-700/30');

      let visibleCount = 0;

      researchCards.forEach(card => {
        const keywords = JSON.parse(card.getAttribute('data-keywords') || '[]');
        
        if (filter === 'all' || keywords.includes(filter)) {
          (card as HTMLElement).style.display = 'block';
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      if (noResults) {
        noResults.classList.toggle('hidden', visibleCount > 0);
      }
    });
  });
</script>
