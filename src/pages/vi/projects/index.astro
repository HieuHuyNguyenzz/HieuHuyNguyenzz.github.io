---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import projects from '../../../data/projects.json';
import vi from '../../../i18n/vi.json';

const t = vi;
const statusLabels: Record<string, string> = {
  completed: t.common.completed,
  'in-progress': t.common.inProgress,
  planned: t.common.planned,
};
const statusColors: Record<string, string> = {
  completed: 'bg-accent-400/20 text-accent-400 border-accent-400/30',
  'in-progress': 'bg-accent-500/20 text-accent-500 border-accent-500/30',
  planned: 'bg-accent-700/20 text-accent-700 border-accent-700/30',
};
---

<BaseLayout title={`${t.projects.pageTitle} | Nguyễn Huy Hiệu`}>
  <Header currentPage="projects" lang="vi" t={t} />
  <main class="pt-20">
    <section class="py-24 relative">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_var(--tw-gradient-stops))] from-accent-500/8 via-accent-900/3 to-transparent"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-900/50 border border-accent-700/30 mb-4">
            <span class="text-accent-400 text-sm font-medium">{t.projects.pageSubtitle}</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold">
            {t.projects.pageTitle} <span class="bg-gradient-to-r from-accent-200 via-accent-400 to-accent-600 bg-clip-text text-transparent">Cá nhân</span>
          </h1>
          <p class="text-accent-300/50 mt-4 max-w-lg mx-auto">
            {t.projects.pageDesc}
          </p>
        </div>

        <div class="space-y-8">
          {projects.map((p) => (
            <div class="group relative bg-dark-card border border-dark-border rounded-2xl overflow-hidden hover:border-accent-500/40 transition-all duration-500">
              <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-400/60 via-accent-500/40 to-transparent group-hover:from-accent-300/80 group-hover:via-accent-400/60 transition-all duration-500"></div>

              <div class="p-6">
                <div class="flex items-start justify-between gap-4 mb-4">
                  <div>
                    <div class="flex items-center gap-3 mb-2">
                      <h3 class="text-lg font-semibold text-accent-200 group-hover:text-accent-300 transition-colors duration-300">
                        {p.title}
                      </h3>
                      <span class={`px-2 py-0.5 text-xs rounded-full border ${statusColors[p.status] || statusColors.planned}`}>
                        {statusLabels[p.status] || statusLabels.planned}
                      </span>
                    </div>
                    <p class="text-accent-300/50 text-sm">{p.shortDesc}</p>
                  </div>
                  <span class="text-accent-300/30 text-xs whitespace-nowrap">{p.date}</span>
                </div>

                {p.screenshots.length > 0 ? (
                  <div class="mb-4 rounded-lg overflow-hidden border border-dark-border">
                    <img src={p.screenshots[0]} alt={p.title} class="w-full h-48 object-cover" />
                  </div>
                ) : (
                  <div class="mb-4 rounded-lg border border-dark-border border-dashed flex items-center justify-center h-32">
                    <span class="text-accent-300/30 text-sm"><i class="fas fa-image mr-2"></i>Ảnh chụp màn hình</span>
                  </div>
                )}

                <div class="mb-4">
                  <h4 class="text-xs uppercase tracking-wide text-accent-400 mb-2 font-medium">Công nghệ</h4>
                  <div class="flex flex-wrap gap-2">
                    {p.techStack.map(tech => (
                      <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>

                <div class="mb-4">
                  <h4 class="text-xs uppercase tracking-wide text-accent-400 mb-2 font-medium">Kết quả</h4>
                  <ul class="space-y-1.5">
                    {p.results.slice(0, 3).map(result => (
                      <li class="flex items-start gap-2 text-sm text-accent-300/60">
                        <i class="fas fa-arrow-trend-up text-accent-400 text-xs mt-1 flex-shrink-0"></i>
                        <span>{result}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="flex flex-wrap items-center gap-3 pt-4 border-t border-dark-border">
                  <a href={`/vi/projects/${p.slug}`} class="inline-flex items-center gap-2 text-sm text-accent-400 hover:text-accent-300 transition-colors">
                    {t.common.viewDetails} <i class="fas fa-arrow-right text-xs"></i>
                  </a>
                  {p.githubLink && p.githubLink !== '#' && (
                    <a href={p.githubLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs text-accent-300/50 hover:text-accent-400 transition-colors">
                      <i class="fab fa-github"></i> Source
                    </a>
                  )}
                  {p.demoLink && p.demoLink !== '#' && (
                    <a href={p.demoLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs text-accent-300/50 hover:text-accent-400 transition-colors">
                      <i class="fas fa-external-link-alt"></i> Demo
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
