---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import projects from '../../data/projects.json';
import en from '../../i18n/en.json';

const t = en;
const statusLabels: Record<string, string> = {
  completed: t.common.completed,
  'in-progress': t.common.inProgress,
  planned: t.common.planned,
};
const statusColors: Record<string, string> = {
  completed: 'bg-accent-400/20 text-accent-400 border-accent-400/30',
  'in-progress': 'bg-accent-500/20 text-accent-500 border-accent-500/30',
  planned: 'bg-accent-700/20 text-accent-700 border-accent-700/30',
};
---

<BaseLayout title={`${t.projects.pageTitle} | Huy Hieu Nguyen`}>
  <Header currentPage="projects" lang="en" t={t} />
  <main class="pt-20">
    <section class="py-24 relative">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_var(--tw-gradient-stops))] from-accent-500/8 via-accent-900/3 to-transparent"></div>

      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-900/50 border border-accent-700/30 mb-4">
            <span class="text-accent-400 text-sm font-medium">{t.projects.pageSubtitle}</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold">
            {t.projects.pageTitle} <span class="bg-gradient-to-r from-accent-200 via-accent-400 to-accent-600 bg-clip-text text-transparent">Projects</span>
          </h1>
          <p class="text-accent-300/50 mt-4 max-w-lg mx-auto">
            {t.projects.pageDesc}
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.map((p) => (
            <a href={`/projects/${p.slug}`} class="group relative bg-dark-card border border-dark-border rounded-2xl p-6 hover:border-accent-500/50 transition-all duration-500 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent-500/10 overflow-hidden block">
              <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-400/60 via-accent-500/40 to-transparent group-hover:from-accent-300/80 group-hover:via-accent-400/60 transition-all duration-500"></div>

              <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 rounded-lg bg-accent-900/60 border border-accent-700/30 flex items-center justify-center">
                  <i class="fas fa-code text-accent-400 text-sm"></i>
                </div>
                <span class={`px-2 py-0.5 text-xs rounded-full border ${statusColors[p.status] || statusColors.planned}`}>
                  {statusLabels[p.status] || statusLabels.planned}
                </span>
              </div>

              <h3 class="text-lg font-semibold mb-2 text-accent-200 group-hover:text-accent-300 transition-colors duration-300">
                {p.title}
              </h3>

              <p class="text-accent-300/50 text-sm leading-relaxed mb-4">
                {p.shortDesc}
              </p>

              <div class="flex flex-wrap gap-2 mb-3">
                {p.techStack.slice(0, 3).map(tech => (
                  <span class="px-3 py-1 text-xs rounded-full bg-accent-900/60 text-accent-400 border border-accent-700/30">
                    {tech}
                  </span>
                ))}
              </div>

              <span class="inline-flex items-center gap-2 text-sm text-accent-400 group-hover:text-accent-300 transition-colors">
                {t.common.viewDetails} <i class="fas fa-arrow-right text-xs group-hover:translate-x-1 transition-transform duration-300"></i>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
