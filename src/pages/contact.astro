---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import en from '../i18n/en.json';

const t = en;
---

<BaseLayout title={`${t.contact.pageTitle} | Huy Hieu Nguyen`}>
  <Header currentPage="contact" lang="en" t={t} />
  <main class="pt-20">
    <section class="py-24 relative">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-accent-700/8 via-accent-900/3 to-transparent"></div>
      <div class="absolute bottom-1/4 left-1/3 w-80 h-80 bg-accent-900/15 rounded-full blur-3xl"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-900/50 border border-accent-700/30 mb-4">
            <span class="text-accent-400 text-sm font-medium">{t.contact.pageSubtitle}</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">
            {t.contact.title}
          </h1>
          <p class="text-accent-300/50 max-w-lg mx-auto">
            {t.contact.desc}
          </p>
        </div>

        <div class="bg-dark-card border border-dark-border rounded-2xl p-8 md:p-12 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-accent-500/60 via-accent-700/40 to-transparent"></div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-6">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-lg bg-accent-900/60 border border-accent-700/30 flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-envelope text-accent-400"></i>
                </div>
                <div>
                  <p class="text-xs text-accent-300/40 mb-1">{t.contact.email}</p>
                  <a href="mailto:huyhieu1422002@gmail.com" class="text-accent-300/70 hover:text-accent-300 transition-colors duration-300 break-all text-sm">
                    huyhieu1422002@gmail.com
                  </a>
                </div>
              </div>

              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-lg bg-accent-900/60 border border-accent-700/30 flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-map-marker-alt text-accent-400"></i>
                </div>
                <div>
                  <p class="text-xs text-accent-300/40 mb-1">{t.contact.location}</p>
                  <p class="text-accent-300/70 text-sm">Hanoi, Vietnam</p>
                </div>
              </div>
            </div>

            <div class="space-y-4">
              <p class="text-xs text-accent-300/40 mb-4">{t.contact.findMeOn}</p>
              <div class="flex flex-wrap gap-3">
                <a href="https://github.com/HieuHuyNguyenzz?tab=repositories" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-dark border border-dark-border hover:border-accent-700/50 transition-all duration-300 group">
                  <i class="fab fa-github text-accent-300/50 group-hover:text-accent-400 transition-colors"></i>
                  <span class="text-sm text-accent-300/70 group-hover:text-accent-300 transition-colors">GitHub</span>
                </a>
                <a href="https://www.linkedin.com/in/hiệu-nguyễn-75b53b360" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-dark border border-dark-border hover:border-accent-700/50 transition-all duration-300 group">
                  <i class="fab fa-linkedin text-accent-300/50 group-hover:text-accent-400 transition-colors"></i>
                  <span class="text-sm text-accent-300/70 group-hover:text-accent-300 transition-colors">LinkedIn</span>
                </a>
                <a href="https://scholar.google.com/citations?user=8hDdHIcAAAAJ&hl=en&oi=ao" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-dark border border-dark-border hover:border-accent-700/50 transition-all duration-300 group">
                  <i class="fas fa-graduation-cap text-accent-300/50 group-hover:text-accent-400 transition-colors"></i>
                  <span class="text-sm text-accent-300/70 group-hover:text-accent-300 transition-colors">Scholar</span>
                </a>
                <a href="https://www.facebook.com/GOD1402/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-dark border border-dark-border hover:border-accent-700/50 transition-all duration-300 group">
                  <i class="fab fa-facebook text-accent-300/50 group-hover:text-accent-400 transition-colors"></i>
                  <span class="text-sm text-accent-300/70 group-hover:text-accent-300 transition-colors">Facebook</span>
                </a>
              </div>
              <a href="/CV.pdf" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg bg-gradient-to-r from-accent-700 to-accent-500 text-white font-medium text-sm hover:shadow-lg hover:shadow-accent-500/25 transition-all duration-300">
                <i class="fas fa-download"></i> Download CV
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
